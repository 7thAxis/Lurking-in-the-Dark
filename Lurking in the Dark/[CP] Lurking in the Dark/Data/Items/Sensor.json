     //----------------------------TRIGGER DATA-------------------------------------//
        {
            "Action": "EditData",
            "Target": "Data/TriggerActions",
            "Entries": {
                "{{ModID}}_Items.SensorFunctional": {
                    "Id": "{{ModID}}_Items.SensorFunctional",
                    "MarkActionApplied": false,
                    "Trigger": "spacechase0.SpaceCore_OnItemUsed",
                    "Condition": "ITEM_ID Input (O){{ModID}}_Items.Sensor, PLAYER_HAS_MAIL Current LitD_M_SenStickerApplied, PLAYER_HAS_MAIL Current LitD_M_StickerObtained",
                    "Actions": [ 
                        "Spiderbuttons.BETAS_PlaySound shadowpeep false",
                        "Spiderbuttons.BETAS_ShakeNPC SenS 10",
                        "Spiderbuttons.BETAS_EmoteNPC SenS 8",
                        "SpiderButtons.BETAS_DialogueBox SenS Strings\\LitD\\DynamicEventStrings:SenS.Sensor"                        
                    ]
                },
                "{{ModID}}_Items.SensorError": {
                    "Id": "{{ModID}}_Items.SensorError",
                    "MarkActionApplied": false,
                    "Trigger": "spacechase0.SpaceCore_OnItemUsed",
                    "Condition": "ITEM_ID Input (O){{ModID}}_Items.Sensor, !PLAYER_HAS_MAIL Current LitD_M_SenStickerApplied, PLAYER_HAS_MAIL Current LitD_M_StickerObtained",
                    "Actions": [ 
                        "SpiderButtons.BETAS_Message Strings\\LitD\\DynamicEventStrings:SenS.SensorError",
                        "Spiderbuttons.BETAS_PlaySound cancel false" 
                    ]
                },
                "{{ModID}}_Items.FirstUse": {
                    "Id": "{{ModID}}_Items.FirstUse",
                    "MarkActionApplied": false,
                    "Trigger": "spacechase0.SpaceCore_OnItemUsed",
                    "Condition": "ITEM_ID Input (O){{ModID}}_Items.Sensor, !PLAYER_HAS_MAIL Current LitD_M_StickerObtained",
                    "Actions": [ 
                        "AddItem {{ModID}}_Items.SenAirTag 1",
                        "SpiderButtons.BETAS_Message Strings\\LitD\\DynamicEventStrings:SenS.StickerDrop",
                        "AddMail Current LitD_M_StickerObtained received"                    
                    ]
                }
            } 
        },
